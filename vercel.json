{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "cleanUrls": true,
  "trailingSlash": false,
  "images": {
    "sizes": [
      320,
      480,
      640,
      750,
      828,
      1080,
      1200,
      1920,
      2048,
      3840
    ],
    "domains": [],
    "minimumCacheTTL": 60,
    "formats": [
      "image/avif",
      "image/webp"
    ],
    "dangerouslyAllowSVG": true,
    "contentSecurityPolicy": "script-src 'none'; frame-src 'none'; sandbox;"
  }
}
